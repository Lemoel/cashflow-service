root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{kt,kts}]
max_line_length = 150
ktlint_standard_package-name = disabled
# Permite linha em branco entre parâmetros (ex.: construtor de entidades)
ktlint_standard_no-blank-line-in-list = disabled

[Makefile]
indent_style = tab
